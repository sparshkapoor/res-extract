# Copy to .env and fill in as needed. All values shown are the defaults
# from app/config.py — only override what you need to change.

# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_KEEP_ALIVE=-1
# OLLAMA_NUM_CTX=32768

# ASR_MODEL_NAME=mlx-community/whisper-small-mlx
# VLM_MODEL_NAME=mlx-community/Qwen2.5-VL-3B-Instruct-4bit

# Required for Instagram Reels — export via:
#   yt-dlp --cookies-from-browser firefox --cookies storage/instagram_cookies.txt --skip-download "<reel-url>"
INSTAGRAM_COOKIES_FILE=/absolute/path/to/backend/storage/instagram_cookies.txt
